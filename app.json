{
  "expo": {
    "name": "Krishidas",
    "slug": "agriconnect-native",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "agriconnectnative",
    "userInterfaceStyle": "automatic",

    "newArchEnabled": true,

    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "We need your location to show nearby machines and labor providers.",
        "NSCameraUsageDescription": "Camera access is needed to upload machine images.",
        "NSPhotoLibraryUsageDescription": "Photo library access is needed to upload images."
      }
    },

    "android": {
      "package": "com.annapradata.agriconnectnative",

      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ],
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },

    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },

"plugins": [
  "expo-router",
  [
    "expo-splash-screen",
    {
      "image": "./assets/images/splash-icon.png",
      "imageWidth": 200,
      "resizeMode": "contain",
      "backgroundColor": "#ffffff",
      "dark": {
        "backgroundColor": "#000000"
      }
    }
  ],
  [
    "expo-location",
    {
      "locationWhenInUsePermission": "Allow Krishidas to access your location to show nearby machines and labor."
    }
  ]
],

    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },

    "extra": {
      "router": {},
      "eas": {
        "projectId": "820ab036-ebd8-4a44-b0c6-ce29b90db245"
      }
    }
  }
}